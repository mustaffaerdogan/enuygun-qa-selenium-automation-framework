<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="Enuygun.com Test Suite" verbose="1">
    
    <!-- Suite level parameters -->
    <parameter name="browser" value="chrome"/>
    
    <!-- Listeners -->
    <listeners>
        <listener class-name="com.mustafa.listeners.TestListener"/>
    </listeners>
    
    <!-- =====================================================
         ALL ENUYGUN TESTS - Tüm 4 test case
         Kullanım: Tüm testleri çalıştırmak için
         ===================================================== -->
    <test name="Enuygun All Tests" enabled="true">
        <classes>
            <class name="com.mustafa.tests.FlightSearchTest"/>
            <class name="com.mustafa.tests.PriceSortingTest"/>
            <class name="com.mustafa.tests.CriticalPathTest"/>
            <class name="com.mustafa.tests.DataExtractionTest"/>
        </classes>
    </test>
    
    <!-- =====================================================
         INDIVIDUAL TEST SUITES - Her test ayrı ayrı çalışabilir
         ===================================================== -->
    
    <!-- Case 1: Basic Flight Search and Time Filter -->
    <test name="Case 1 - Flight Search" enabled="false">
        <classes>
            <class name="com.mustafa.tests.FlightSearchTest"/>
        </classes>
    </test>
    
    <!-- Case 2: Price Sorting for Turkish Airlines -->
    <test name="Case 2 - Price Sorting" enabled="false">
        <classes>
            <class name="com.mustafa.tests.PriceSortingTest"/>
        </classes>
    </test>
    
    <!-- Case 3: Critical Path Testing -->
    <test name="Case 3 - Critical Path" enabled="false">
        <classes>
            <class name="com.mustafa.tests.CriticalPathTest"/>
        </classes>
    </test>
    
    <!-- Case 4: Data Extraction and Analysis -->
    <test name="Case 4 - Data Extraction" enabled="false">
        <classes>
            <class name="com.mustafa.tests.DataExtractionTest"/>
        </classes>
    </test>
    
    <!-- =====================================================
         PARALLEL EXECUTION - Hızlı çalıştırma
         ===================================================== -->
    <test name="Parallel Execution" enabled="false" parallel="classes" thread-count="4">
        <classes>
            <class name="com.mustafa.tests.FlightSearchTest"/>
            <class name="com.mustafa.tests.PriceSortingTest"/>
            <class name="com.mustafa.tests.CriticalPathTest"/>
            <class name="com.mustafa.tests.DataExtractionTest"/>
        </classes>
    </test>
    
</suite>
